# ─────────────────────────────────────────────
# RAG Project — Environment Variables Template
# Copy this file to .env and fill in your values
# Never commit .env to version control
# ─────────────────────────────────────────────

# App
APP_ENV=development
SECRET_KEY=your-long-random-secret-key-here

# Database
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragdb

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-bucket

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# LLM — change this one line to switch provider (groq, ollama, openai)
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Ollama (local — keep for fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (production option)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_LLM_MODEL=gpt-4o-mini

# Sentry (optional — leave empty to disable)
SENTRY_DSN=
